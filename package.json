{
  "name": "shogi-mobile-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "bun run format:check && bun run typecheck",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:unit": "bun test",
    "skills:v2:catalog": "node scripts/apply-skill-definition-v2-catalog.mjs",
    "skills:v2:catalog:apply": "node scripts/apply-skill-definition-v2-catalog.mjs --apply",
    "seed:piece-images": "node scripts/seed-master-piece-image-keys.mjs",
    "seed:piece-images:storage": "node scripts/upload-piece-images-to-storage.mjs",
    "reset:users": "node scripts/reset-auth-users.mjs",
    "reset:users:apply": "node scripts/reset-auth-users.mjs --apply",
    "format": "biome format app src lib scripts docs .github package.json tsconfig.json next.config.ts README.md --write",
    "format:check": "biome format app src lib scripts docs .github package.json tsconfig.json next.config.ts README.md",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "dotenv": "^17.3.1",
    "next": "^15.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.8.3",
    "@biomejs/biome": "^2.4.6",
    "lefthook": "^2.1.3"
  }
}
